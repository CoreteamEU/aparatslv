{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Local Server",
            "type": "shell",
            "command": "python3",
            "args": [
                "-m",
                "http.server",
                "8080"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Serving HTTP on :: port 8080",
                    "endsPattern": "Serving HTTP on :: port 8080"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}